    "nizel-plugin-media": "^0.1.0",
    "nizel-plugin-sanitize": "^0.1.0",
    "nizel-plugin-shiki": "^0.1.1",
    "nizel-plugin-toc": "^0.1.0",
    "nizel-plugin-typography": "^0.1.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
