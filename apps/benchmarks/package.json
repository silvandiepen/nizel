{
  "name": "nizel-benchmarks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Performance comparison benchmarks for Nizel and other Markdown parsers.",
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
