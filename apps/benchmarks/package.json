{
  "name": "nizel-benchmarks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Performance comparison benchmarks for Nizel and other Markdown parsers.",
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "benchmark": "node src/benchmark.js",
    "bench": "npm run benchmark",
    "benchmark:plugins": "node src/plugin-overhead-benchmark.js",
    "benchmark:nizel": "node src/nizel-function-benchmark.js",
    "bench:nizel": "npm run benchmark:nizel",
    "fixtures:commonmark": "node scripts/build-commonmark-fixture.js",
    "test": "node -e \"process.exit(0)\"",
    "typecheck": "node -e \"process.exit(0)\"",
    "test:run": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "commonmark-spec": "^0.31.2",
    "markdown-it": "^14.1.0",
    "marked": "^18.0.3",
    "nizel": "^0.1.0",
    "nizel-kit": "^0.1.0",
    "nizel-plugin-abbr": "^0.1.0",
    "nizel-plugin-alert": "^0.1.0",
    "nizel-plugin-autolink": "^0.1.0",
    "nizel-plugin-citations": "^0.1.0",
    "nizel-plugin-code-copy": "^0.1.0",
    "nizel-plugin-deflist": "^0.1.0",
    "nizel-plugin-details": "^0.1.0",
    "nizel-plugin-diagrams": "^0.1.0",
    "nizel-plugin-emoji": "^0.1.0",
    "nizel-plugin-footnotes": "^0.1.0",
    "nizel-plugin-frontmatter-ui": "^0.1.0",
    "nizel-plugin-gfm": "^0.1.0",
