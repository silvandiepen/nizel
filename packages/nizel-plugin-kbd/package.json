{
  "name": "nizel-plugin-kbd",
  "version": "0.1.0",
  "description": "Keyboard shortcut rendering plugin for Nizel.",
  "repository": {
    "type": "git",
    "url": "https://github.com/silvandiepen/nizel"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./style.css"
  },
  "files": [
    "dist",
    "README.md",
    "style.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && vitest run test/*.mjs",
    "test:watch": "npm run build && vitest test/*.mjs",
    "test:run": "vitest run test/*.mjs"
  },
  "peerDependencies": {
    "nizel": "^0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
