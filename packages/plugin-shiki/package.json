{
  "name": "nizel-plugin-shiki",
  "version": "0.1.1",
  "description": "Optional code highlighting integration point for Nizel.",
  "repository": {
    "type": "git",
    "url": "https://github.com/silvandiepen/nizel"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./javascript": {
      "types": "./dist/javascript.d.ts",
      "import": "./dist/javascript.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && vitest run test/*.mjs",
    "test:watch": "npm run build && vitest test/*.mjs",
    "test:run": "vitest run test/*.mjs"
  },
  "peerDependencies": {
    "nizel": "^0.1.0",
    "shiki": "^4.0.2"
  },
  "peerDependenciesMeta": {
    "shiki": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "miniflare": "^4.20260430.0",
    "shiki": "^4.0.2"
  }
}
