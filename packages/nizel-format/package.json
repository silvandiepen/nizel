{
  "name": "nizel-format",
  "version": "0.1.4",
  "description": "Markdown formatter utilities for Nizel.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/nizel.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nizel-format": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:browser",
    "build:browser": "esbuild src/index.ts --bundle --platform=browser --format=esm --target=safari14 --outfile=dist/nizel-format.js && esbuild src/index.ts --bundle --platform=browser --format=iife --global-name=NizelFormat --target=safari14 --outfile=dist/nizel-format.iife.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && vitest run test/*.mjs",
    "test:run": "vitest run test/*.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "esbuild": "^0.27.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
